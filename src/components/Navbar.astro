---
// Recibimos las categorías por props. Si no hay (como en la Home), se queda vacío y no da error.
const { categorias = [] } = Astro.props;
---

<nav class="hidden md:flex sticky top-0 left-0 w-full z-50 justify-between items-center px-10 h-20 text-white bg-[#1e468d] border-b border-[#222]">
  <div class="flex items-center">
    <a href="/">
      <img 
        src="/logolinealsinpalmera.png" 
        alt="Nomads Garden Logo" 
        class="h-7 w-auto object-contain hover:opacity-80 transition-opacity" 
      />
    </a>
    </div>
  
  <div class="flex gap-8 font-bebas text-xl tracking-wider text-gray-200">
    <a href="/" class="hover:text-[#e4a055] transition-colors">INICIO</a>
    <a href="/carta" class="hover:text-[#e4a055] transition-colors">CARTA</a>
<a href="/#contacto" class="hover:text-[#e4a055] transition-colors">CONTACTO</a>  </div>
</nav>

{categorias.length > 0 && (
  <div class="sticky top-0 md:top-20 z-40 w-full bg-[#111111] border-b border-[#222] shadow-md transition-all duration-200">
    <div class="max-w-7xl mx-auto flex items-center">
      <div class="flex-1 flex overflow-x-auto no-scrollbar gap-8 px-6 font-bebas text-xl text-gray-400 tracking-wider">
        {categorias.map((categoria) => (
          <a 
            href={`#categoria-${categoria.id}`} 
            class="cat-link whitespace-nowrap py-3 transition-colors border-b-2 uppercase border-transparent hover:text-white hover:border-[#3b82f6]"
          >
            {categoria.name}
          </a>
        ))}
      </div>
    </div>
  </div>
)}

<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 bg-[#111111]/95 backdrop-blur-md border-t border-[#333] pb-2 pt-2 shadow-[0_-4px_20px_rgba(0,0,0,0.5)]">
  <div class="flex justify-around items-center text-sm font-bebas text-gray-400 tracking-wider px-2">
    
    <a href="/" class="flex flex-col items-center gap-1 hover:text-[#e4a055] transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
      INICIO
    </a>

    <a href="/carta" class="flex flex-col items-center gap-1 hover:text-[#e4a055] transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477-4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
      CARTA
    </a>

    <a href="#contacto" class="flex flex-col items-center gap-1 hover:text-[#e4a055] transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
      CONTACTO
    </a>

  </div>
</nav>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const catLinks = document.querySelectorAll('.cat-link'); 
    
    const updateActiveCategory = () => {
      let currentSectionId = '';
      const scrollPosition = window.scrollY + 160; 
      
      const sections = document.querySelectorAll('[id^="categoria-"]');
      sections.forEach(section => {
        if ((section as HTMLElement).offsetTop <= scrollPosition) {
          currentSectionId = section.getAttribute('id') || '';
        }
      });

      catLinks.forEach(link => {
        if (link.getAttribute('href') === `#${currentSectionId}`) {
          link.classList.add('text-white', 'border-[#3b82f6]');
          link.classList.remove('text-gray-400', 'border-transparent');
        } else {
          link.classList.remove('text-white', 'border-[#3b82f6]');
          link.classList.add('text-gray-400', 'border-transparent');
        }
      });
    };

    window.addEventListener('scroll', updateActiveCategory);
    setTimeout(updateActiveCategory, 100);
  });
</script>