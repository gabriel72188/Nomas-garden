---
const { categorias } = Astro.props;
---

<div id="scrolled-top-bar" class="fixed top-0 left-0 w-full z-[70] h-[56px] bg-cover bg-center opacity-0 pointer-events-none transition-opacity duration-200 shadow-md font-sans" style="background-image: url('/headerimagen2.webp');">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
  
  <div class="relative z-10 flex items-center h-full px-4 max-w-6xl mx-auto">
    <div class="flex items-center gap-3">
      <img src="/logo.png" alt="Logo" class="w-8 h-8 rounded-md shadow-sm object-cover" />
      <span class="font-bold text-[15px] tracking-tight text-white font-sans">Nomads Garden Market</span>
    </div>
  </div>
</div>

<section class="w-full bg-[#111111] mb-0 font-sans relative z-[60]">
  
  <div class="relative h-32 md:h-48 w-full bg-cover bg-center" style="background-image: url('/headerimagen2.webp');">
    <div class="absolute inset-0 bg-black/40 backdrop-blur"></div>
  </div>
  
  <div class="relative px-6 pb-6 pt-14 max-w-6xl mx-auto">
    <div class="absolute -top-10 left-6">
      <img src="/logo.png" alt="Logo Perfil" class="w-20 h-20 rounded-xl border-4 border-[#111111] object-cover shadow-md" />
    </div>

    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-6">
      
      <div>
        <h1 class="font-bebas text-4xl tracking-wide text-white mb-1">NOMADS GARDEN Market</h1>
        
        <div id="horario-toggle" class="relative group font-inco text-sm text-gray-400 flex items-center gap-2 mb-3 w-max cursor-pointer select-none">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          
          <span id="texto-horario-hoy">Horarios Hoy ...</span>
          <span id="badge-horario" class="hidden text-red-500 font-semibold uppercase font-sans text-xs bg-red-500/10 px-2 py-0.5 rounded">Cerrado</span>
          
          <svg id="horario-arrow" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>

          <div id="horario-menu" class="absolute top-full left-0 mt-2 w-72 bg-[#1a1a1a] border border-[#333] rounded-md shadow-xl opacity-0 invisible transition-all duration-200 z-50 overflow-hidden font-sans">
            <ul class="text-xs text-gray-400">
              <li class="flex justify-between px-4 py-2 border-b border-gray-700/50 border-dashed"><span class="text-white">Lunes</span><span>Cerrado</span></li>
              <li class="flex justify-between px-4 py-2 border-b border-gray-700/50 border-dashed"><span class="text-white">Martes</span><span>Cerrado</span></li>
              <li class="flex justify-between px-4 py-2 border-b border-gray-700/50 border-dashed"><span class="text-white">Miércoles</span><span>Cerrado</span></li>
              <li class="flex justify-between px-4 py-2 border-b border-gray-700/50 border-dashed"><span class="text-white">Jueves</span><span>19:00 a 23:30</span></li>
              <li class="flex justify-between px-4 py-2 border-b border-gray-700/50 border-dashed"><span class="text-white">Viernes</span><span>12:00 a 16:00 y 19:00 a 00:00</span></li>
              <li class="flex justify-between px-4 py-2 border-b border-gray-700/50 border-dashed"><span class="text-white">Sábado</span><span>12:00 a 16:00 y 19:00 a 00:00</span></li>
              <li class="flex justify-between px-4 py-2"><span class="text-white">Domingo</span><span>12:00 a 17:00</span></li>
            </ul>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 mt-4 font-sans">
          <a href="tel:640620913" class="bg-[#1a1a1a] hover:bg-[#2a2a2c] text-green-500 px-3 py-1.5 rounded-full text-[13px] font-semibold flex items-center gap-1.5 transition-colors border border-transparent hover:border-green-500/30">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            Llamar
          </a>

          <a href="https://wa.me/34640620913?text=Hola%2C+estoy+viendo+su+menú+y+me+gustaría+hacer+una+consulta." target="_blank" class="bg-[#1a1a1a] hover:bg-[#2a2a2c] text-green-400 px-3 py-1.5 rounded-full text-[13px] font-semibold flex items-center gap-1.5 transition-colors border border-transparent hover:border-green-400/30">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.414 0 .018 5.393 0 12.029a11.794 11.794 0 001.591 5.919L0 24l6.112-1.605a11.777 11.777 0 005.932 1.633h.005c6.634 0 12.032-5.396 12.035-12.032a11.761 11.761 0 00-3.489-8.492"/></svg>
            WhatsApp
          </a>

          <a href="mailto:nomadsgardenmarket@gmail.com" class="bg-[#1a1a1a] hover:bg-[#2a2a2c] text-gray-300 px-3 py-1.5 rounded-full text-[13px] font-semibold flex items-center gap-1.5 transition-colors border border-transparent hover:border-gray-500/30">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            Email
          </a>
        </div>

        <div class="mt-4">
          <a href={categorias && categorias.length > 0 ? `#categoria-${categorias[0].id}` : '/carta'} class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-semibold inline-flex items-center gap-2 transition-colors font-sans tracking-wide cursor-pointer w-max">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg> Menú
          </a>
        </div>

      <div class="shrink-0 w-full md:w-auto mt-4 md:mt-0">
        <a href="https://maps.app.goo.gl/TXE9hAwa2z1T5xpH8" target="_blank" class="block w-full md:w-64 rounded-xl overflow-hidden border border-[#333] hover:border-gray-500 transition-all group shadow-lg">
          <div class="bg-[#1a1a1a] px-4 py-2 text-sm text-gray-300 font-sans text-left flex items-center gap-2">
            <span>Donde estamos</span>
          </div>
          
          <div class="h-24 w-full relative bg-[#222] overflow-hidden rounded-b-xl">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3171.24712922412!2d-1.6625089234579946!3d37.360328972092745!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd64cd6476ea57c7%3A0xe0314245bb8a0481!2sNomads%20Garden%20Market!5e0!3m2!1ses!2ses!4v1774273040719!5m2!1ses!2ses" 
              class="absolute inset-0 w-full h-full border-0 rounded-b-xl"
              title="Ubicación de Nomads Garden Market"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            >
            </iframe>
            
            <div class="absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-colors pointer-events-none"></div>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<nav id="category-bar" class="sticky top-0 z-40 w-full bg-[#111111] border-b border-[#222222] transition-all duration-200" style="top: 0px;">
  <div class="max-w-6xl mx-auto flex items-center">
    <div class="flex-1 flex overflow-x-auto no-scrollbar gap-8 px-6 font-bebas text-xl text-gray-400 tracking-wide">
      {categorias?.map((categoria) => (
        <a 
          href={`#categoria-${categoria.id}`} 
          class="cat-link whitespace-nowrap py-3 transition-colors border-b-2 uppercase text-gray-400 border-transparent hover:text-white hover:border-gray-600"
        >
          {categoria.name}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // Lógica de los Horarios
    const horariosSemanales = [
      '12:00 a 17:00', // 0: Domingo
      'Cerrado',       // 1: Lunes
      'Cerrado',       // 2: Martes
      'Cerrado',       // 3: Miércoles
      '19:00 a 23:30', // 4: Jueves
      '12:00 a 16:00 y 19:00 a 00:00', // 5: Viernes
      '12:00 a 16:00 y 19:00 a 00:00'  // 6: Sábado
    ];
    
    const diaHoy = new Date().getDay();
    const horarioDeHoy = horariosSemanales[diaHoy];
    const textoHoy = document.getElementById('texto-horario-hoy');
    const badge = document.getElementById('badge-horario');

    if (textoHoy) {
      if (horarioDeHoy === 'Cerrado') {
        textoHoy.innerText = 'Horarios Hoy';
        if (badge) badge.classList.remove('hidden'); 
      } else {
        textoHoy.innerText = `Horarios Hoy ${horarioDeHoy}`;
        if (badge) badge.classList.add('hidden');
      }
    }

    // Lógica para el menú de horarios
    const horarioToggle = document.getElementById('horario-toggle');
    const horarioMenu = document.getElementById('horario-menu');
    const horarioArrow = document.getElementById('horario-arrow');

    if (horarioToggle && horarioMenu) {
      horarioToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        horarioMenu.classList.toggle('opacity-0');
        horarioMenu.classList.toggle('invisible');
        horarioMenu.classList.toggle('opacity-100');
        horarioMenu.classList.toggle('visible');
        if (horarioArrow) horarioArrow.classList.toggle('rotate-180');
      });

      document.addEventListener('click', (e) => {
        if (!horarioToggle.contains(e.target as Node)) {
          horarioMenu.classList.add('opacity-0', 'invisible');
          horarioMenu.classList.remove('opacity-100', 'visible');
          if (horarioArrow) horarioArrow.classList.remove('rotate-180');
        }
      });
    }

    // Lógica del Doble Sticky y Scrollspy
    const topBar = document.getElementById('scrolled-top-bar');
    const catBar = document.getElementById('category-bar');
    const catLinks = document.querySelectorAll('.cat-link'); 
    
    const updateActiveCategory = () => {
      let currentSectionId = '';
      const scrollPosition = window.scrollY + 180; 
      
      const sections = document.querySelectorAll('[id^="categoria-"]');
      sections.forEach(section => {
        if ((section as HTMLElement).offsetTop <= scrollPosition) {
          currentSectionId = section.getAttribute('id') || '';
        }
      });

      catLinks.forEach(link => {
        if (link.getAttribute('href') === `#${currentSectionId}`) {
          link.classList.add('text-white', 'border-[#3b82f6]');
          link.classList.remove('text-gray-400', 'border-transparent', 'hover:border-gray-600');
        } else {
          link.classList.remove('text-white', 'border-[#3b82f6]');
          link.classList.add('text-gray-400', 'border-transparent', 'hover:border-gray-600');
        }
      });
    };

    window.addEventListener('scroll', () => {
      if (window.scrollY > 150) {
        if(topBar) topBar.classList.remove('opacity-0', 'pointer-events-none');
        if(topBar) topBar.classList.add('opacity-100', 'pointer-events-auto');
        if(catBar) catBar.style.top = '56px';
      } else {
        if(topBar) topBar.classList.add('opacity-0', 'pointer-events-none');
        if(topBar) topBar.classList.remove('opacity-100', 'pointer-events-auto');
        if(catBar) catBar.style.top = '0px';
      }
      updateActiveCategory();
    });

    setTimeout(updateActiveCategory, 100);
  });
</script>