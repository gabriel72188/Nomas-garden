---
import '../styles/global.css';
import PlatoCard from '../components/PlatoCard.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const API_URL = import.meta.env.WP_API_URL;

// 1. Obtener Platos
const resPlatos = await fetch(`${API_URL}/plato?_embed&per_page=100`);
const platos = await resPlatos.json();

// 2. Obtener TODAS las categorías (Padres e Hijos)
const resCategorias = await fetch(`${API_URL}/categoria_plato?per_page=100&acf_format=standard`);
let categorias = await resCategorias.json();

// Ordenarlas por el campo ACF "orden"
categorias.sort((a, b) => {
  const ordenA = a.acf?.orden ? parseInt(a.acf.orden) : 99;
  const ordenB = b.acf?.orden ? parseInt(b.acf.orden) : 99;
  return ordenA - ordenB;
});

// 3. Separar Padres (Puestos) de Hijos (Subcategorías)
const categoriasPrincipales = categorias.filter(cat => cat.parent === 0);
const subCategorias = categorias.filter(cat => cat.parent !== 0);

// 4. Obtener Alérgenos
const resAlergenos = await fetch(`${API_URL}/alergeno?acf_format=standard&per_page=100`);
const alergenosData = await resAlergenos.json();

const infoAlergenos = {};
alergenosData.forEach(alergeno => {
  infoAlergenos[alergeno.id] = {
    url: alergeno.acf?.icono || null,
    nombre: alergeno.name || "Alérgeno" 
  }; 
});
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <title>Carta - Nomads Garden</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inconsolata:wght@300;400;500;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#f0ece5] text-gray-950 min-h-screen font-sans transition-colors duration-300">
    
    <Navbar categorias={categoriasPrincipales} />

    <main class="p-8">
      <div class="max-w-6xl mx-auto">
        
        {categoriasPrincipales.map(puesto => {
          
          // Buscar las subcategorías que pertenecen a este puesto
          const subcatsDelPuesto = subCategorias.filter(sub => sub.parent === puesto.id);

          // Buscar platos que están marcados en el Puesto pero NO en ninguna subcategoría (Platos "sueltos")
          const platosDirectos = platos.filter(plato => 
            plato.categoria_plato && 
            plato.categoria_plato.includes(puesto.id) &&
            !subcatsDelPuesto.some(sub => plato.categoria_plato.includes(sub.id))
          );

          // Comprobar si este puesto tiene algo que mostrar (platos directos o subcategorías con platos)
          const tienePlatosDirectos = platosDirectos.length > 0;
          const tieneSubcategoriasConPlatos = subcatsDelPuesto.some(sub => 
            platos.some(plato => plato.categoria_plato && plato.categoria_plato.includes(sub.id))
          );

          if (!tienePlatosDirectos && !tieneSubcategoriasConPlatos) return null;

          return (
            <div class="mb-20 scroll-mt-28" id={`categoria-${puesto.id}`}>
              
              {/* TÍTULO DEL PUESTO */}
              <div class="border-b-2 border-[#e4a055] pb-2 mb-8">
                <h1 class="font-bebas text-6xl tracking-wide text-gray-950">{puesto.name}</h1>
                {puesto.description && (
                  <p class="font-bebas text-xl tracking-wide text-gray-500 uppercase mt-2">{puesto.description}</p>
                )}
              </div>

              {/* PLATOS DIRECTOS DEL PUESTO (Sin subcategoría) */}
              {tienePlatosDirectos && (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
                  {platosDirectos.map((plato) => {
                    const imagenUrl = plato._embedded?.['wp:featuredmedia']?.[0]?.source_url;
                    return <PlatoCard plato={plato} imagenUrl={imagenUrl} infoAlergenos={infoAlergenos} />;
                  })}
                </div>
              )}

              {/* SUBCATEGORÍAS*/}
              {subcatsDelPuesto.map(subcat => {
                const platosDeSubcat = platos.filter(plato => 
                  plato.categoria_plato && plato.categoria_plato.includes(subcat.id)
                );

                if (platosDeSubcat.length === 0) return null;

                return (
                  <div class="mb-12">
                    <h2 class="font-bebas text-4xl text-[#e4a055] tracking-wide mb-6 flex items-center gap-4">
                      {subcat.name}
                      <span class="h-px bg-[#e4a055]/30 flex-1"></span>
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                      {platosDeSubcat.map((plato) => {
                        const imagenUrl = plato._embedded?.['wp:featuredmedia']?.[0]?.source_url;
                        return <PlatoCard plato={plato} imagenUrl={imagenUrl} infoAlergenos={infoAlergenos} />;
                      })}
                    </div>
                  </div>
                );
              })}

            </div>
          );
        })}

      </div>
    </main>

  <Footer />
  </body>
</html>