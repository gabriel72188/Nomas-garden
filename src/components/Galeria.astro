---
// src/components/Galeria.astro
---
<section id="galeria" class="relative w-full bg-[#e4a055] pb-16 md:pb-30">
  
  <div class="py-20 md:py-20 text-center">
    <h2 class="font-bebas text-5xl md:text-6xl text-[#ffffff] tracking-widest uppercase">
      TU SITIO ESTE VERANO
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 w-full relative z-10">
    
    <div class="col-span-1 h-[350px] md:h-[400px] lg:h-[450px] bg-gray-400 relative overflow-hidden group">
       <img src="/imagen1.webp" alt="Imagen Pequeña 5" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>

    <div class="col-span-1 h-[350px] md:h-[400px] lg:h-[450px] bg-gray-600 relative overflow-hidden group">
       <img src="/imagen8.webp" alt="Imagen Pequeña 8" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>

    <div class="col-span-1 h-[350px] md:h-[400px] lg:h-[450px] bg-gray-300 relative overflow-hidden group">
       <img src="/imagen3.webp" alt="Imagen Pequeña 6" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>
    
    <div class="col-span-1 h-[350px] md:h-[400px] lg:h-[450px] bg-gray-500 relative overflow-hidden group">
       <img src="/imagen5.webp" alt="Imagen Pequeña 7" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>

    <div class="col-span-1 h-[350px] md:h-[400px] lg:h-[450px] bg-gray-600 relative overflow-hidden group">
       <img src="/imagen6.webp" alt="Imagen Pequeña 8" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>

    <div class="col-span-1 h-[350px] md:h-[400px] lg:h-[450px] bg-gray-600 relative overflow-hidden group">
       <img src="/imagen7.webp" alt="Imagen Pequeña 8" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>

    <div class="col-span-1 md:col-span-2 lg:col-span-2 h-[350px] md:h-[400px] lg:h-[450px] bg-gray-200 relative overflow-hidden group">
       <img src="/imagen2.webp" alt="Imagen Grande 1" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    </div>

  </div>
</section>