---
const { plato, imagenUrl, infoAlergenos } = Astro.props;

// 1. Creamos un ID único para el modal de este plato usando el ID de WordPress
const modalId = `modal-${plato.id}`;

// 2. Extraemos los datos de ACF y preparamos las variaciones
const acf = plato.acf || {};
let variaciones = [];

// Revisamos hasta 4 posibles grupos (opcion_1, opcion_2, opcion_3, opcion_4)
for (let i = 1; i <= 4; i++) {
  const opcion = acf[`opcion_${i}`];
  // Si el grupo existe y tiene rellenado el tamaño y el precio, lo guardamos
  if (opcion && opcion.tamano && opcion.precio) {
    variaciones.push({
      cantidad: opcion.tamano,
      precio: opcion.precio
    });
  }
}

// 3. Calculamos qué precio mostrar en la tarjeta principal
const precioMostrar = variaciones.length > 0 
  ? `desde € ${variaciones[0].precio}` 
  : `€ ${acf.precio || '0'}`;
---

<div 
  class="bg-[#1c1c1e] rounded-xl p-4 flex gap-4 hover:bg-[#252528] transition-colors cursor-pointer border border-transparent hover:border-gray-700 h-full relative"
  data-modal-target={modalId}
>
  {imagenUrl ? (
    <img src={imagenUrl} alt={plato.title.rendered} class="w-24 h-24 object-cover rounded-lg flex-shrink-0" />
  ) : (
    <div class="w-24 h-24 bg-gray-800 rounded-lg flex-shrink-0"></div>
  )}

  <div class="flex-1 flex flex-col">
    <h2 class="font-bold text-lg leading-tight mb-1">{plato.title.rendered}</h2>
    <div class="text-sm text-gray-400 line-clamp-2" set:html={plato.content.rendered}></div>
    
    {plato.alergeno && plato.alergeno.length > 0 && (
      <div class="flex gap-2 mt-2 mb-2">
        {plato.alergeno.map(id => {
          const alergeno = infoAlergenos[id];
          return alergeno?.url ? (
            <div class="relative group flex justify-center focus:outline-none" tabindex="0">
              <img src={alergeno.url} alt={alergeno.nombre} class="w-5 h-5 object-contain cursor-help" />
              <div class="absolute bottom-full mb-2 hidden group-hover:block group-focus:block bg-[#111111] text-white text-xs font-medium py-1 px-2 rounded-md border border-gray-700 whitespace-nowrap z-20 shadow-lg">
                {alergeno.nombre}
              </div>
            </div>
          ) : null;
        })}
      </div>
    )}

    <p class="text-sm font-semibold mt-auto text-gray-200">{precioMostrar}</p>
  </div>
</div>

<dialog 
  id={modalId} 
  class="bg-[#1c1c1e] text-white p-6 rounded-2xl w-[90%] max-w-3xl backdrop:bg-black/80 backdrop:backdrop-blur-sm m-auto shadow-2xl"
>
  <button 
    data-modal-close={modalId} 
    class="absolute top-4 right-4 text-gray-400 hover:text-white text-3xl leading-none cursor-pointer bg-transparent border-none outline-none z-10"
  >
    &times;
  </button>

  <div class="flex flex-col md:flex-row gap-6 mt-4">
    <div class="w-full md:w-1/2">
      {imagenUrl ? (
        <img src={imagenUrl} alt={plato.title.rendered} class="w-full h-64 md:h-full object-cover rounded-xl" />
      ) : (
        <div class="w-full h-64 bg-gray-800 rounded-xl"></div>
      )}
    </div>

    <div class="w-full md:w-1/2 flex flex-col">
      <h2 class="text-2xl font-bold mb-2">{plato.title.rendered}</h2>
      
      <p class="text-xl font-semibold mb-4 text-gray-300">{precioMostrar}</p>
      
      <div class="text-gray-400 mb-6" set:html={plato.content.rendered}></div>

      {plato.alergeno && plato.alergeno.length > 0 && (
        <div class="mb-6">
          <p class="text-sm font-bold text-gray-300 mb-3">Alérgenos</p>
          <div class="flex gap-2">
            {plato.alergeno.map(id => {
              const alergeno = infoAlergenos[id];
              return alergeno?.url ? (
                <div class="relative group flex justify-center focus:outline-none" tabindex="0">
                  <img src={alergeno.url} alt={alergeno.nombre} class="w-8 h-8 object-contain cursor-help" />
                  <div class="absolute bottom-full mb-2 hidden group-hover:block group-focus:block bg-[#111111] text-white text-sm font-medium py-1.5 px-3 rounded-md border border-gray-700 whitespace-nowrap z-50 shadow-lg">
                    {alergeno.nombre}
                  </div>
                </div>
              ) : null;
            })}
          </div>
        </div>
      )}

      {variaciones.length > 0 && (
        <div class="mt-auto">
          <div class="flex items-center mb-3">
            <p class="text-white font-bold text-base">Elige el tamaño</p>
            <span class="bg-orange-600 text-white text-[10px] font-bold px-2 py-0.5 rounded ml-3 uppercase tracking-wider">Obligatorio</span>
          </div>
          
          <div class="flex flex-col border border-gray-700 rounded-lg overflow-hidden">
            {variaciones.map((opcion, index) => (
              <label class="flex justify-between items-center p-4 border-b border-gray-700 last:border-0 hover:bg-gray-800 cursor-pointer transition">
                <div class="flex items-center gap-3">
                  <input 
                    type="radio" 
                    name={`tamano_${plato.id}`} 
                    value={opcion.cantidad} 
                    checked={index === 0}
                    class="w-5 h-5 text-orange-500 bg-gray-900 border-gray-600 focus:ring-orange-500 focus:ring-offset-gray-900" 
                  />
                  <span class="text-gray-200 font-medium">{opcion.cantidad}</span>
                </div>
                <span class="text-gray-400">€ {opcion.precio}</span>
              </label>
            ))}
          </div>
        </div>
      )}
      
    </div>
  </div>
</dialog>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Abrir modales
    const tarjetas = document.querySelectorAll('[data-modal-target]');
    tarjetas.forEach(tarjeta => {
      tarjeta.addEventListener('click', (e) => {
        // Evitamos abrir el modal si hacemos clic en el icono de alérgeno
        if ((e.target as HTMLElement).closest('.group')) return;

        const modalId = tarjeta.getAttribute('data-modal-target');
        const modal = document.getElementById(modalId) as HTMLDialogElement;
        if (modal) modal.showModal();
      });
    });

    // 2. Cerrar modales con la 'X'
    const botonesCerrar = document.querySelectorAll('[data-modal-close]');
    botonesCerrar.forEach(boton => {
      boton.addEventListener('click', () => {
        const modalId = boton.getAttribute('data-modal-close');
        const modal = document.getElementById(modalId) as HTMLDialogElement;
        if (modal) modal.close();
      });
    });

    // 3. Cerrar si se hace clic en el fondo oscuro
    const modales = document.querySelectorAll('dialog');
    modales.forEach(modal => {
      modal.addEventListener('click', (e) => {
        const dialogDimensions = modal.getBoundingClientRect();
        if (
          e.clientX < dialogDimensions.left ||
          e.clientX > dialogDimensions.right ||
          e.clientY < dialogDimensions.top ||
          e.clientY > dialogDimensions.bottom
        ) {
          modal.close();
        }
      });
    });

  });
</script>