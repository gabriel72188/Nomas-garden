---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Nomads Garden Market">
  <Navbar />
  
  <main class="bg-[#111]">
<section class="relative z-10 w-full h-[95vh] md:h-screen bg-cover bg-center overflow-hidden" style="background-image: url('/headerimagen2.webp');">      <div class="absolute inset-0 bg-black/70 backdrop-blur"></div>
      
      <div class="hidden md:flex absolute right-4 lg:right-8 top-0 bottom-0 items-center justify-center z-20 pointer-events-none">
        <span class="font-bebas text-6xl lg:text-8xl text-[#f6eedf]/50 tracking-widest uppercase" style="writing-mode: vertical-rl; transform: rotate(180deg);">
          welcome
        </span>
      </div>
      
      <div class="relative z-30 flex flex-col items-center justify-center h-full px-6 text-center text-white pb-16">
        <img 
          src="/logosinfondoamarillo.png" 
          alt="Nomads Garden Market Logo" 
          class="w-[360px] h-auto md:w-[640px] object-contain mb-8" 
        />
        
        <a href="/carta" class="bg-[#1e468d] hover:bg-white text-white hover:text-[#1e468d] font-bebas text-xl px-10 py-3 rounded-full transition-colors duration-300 tracking-wider">
          VER LA CARTA
        </a>
      </div>

      <div class="absolute bottom-[-1px] left-0 w-full z-30 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none" class="w-full h-16 md:h-24 text-[#f6eedf] fill-current">
          <polygon points="0,0 100,100 0,100" />
        </svg>
      </div>
    </section>

    <section id="nosotros" class="relative z-0 py-20 md:py-32 px-6 bg-[#f6eedf]">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        
        <div class="flex flex-col space-y-6">
          <p class="font-sans font-bold text-[#e4a055] uppercase tracking-widest text-sm">
            Bienvenidos a Nomads Garden
          </p>
          <h2 class="font-bebas text-6xl md:text-8xl text-[#2c1e16] tracking-wider leading-[0.9] uppercase">
            NUESTRO<br>MANIFIESTO
          </h2>
          
          <div class="space-y-4 font-sans text-[#4a382a] text-lg leading-relaxed font-medium">
            <p>
              Nacimos con un sueño claro: crear un espacio vibrante y único donde la gastronomía de autor se encuentre con el espíritu libre. Un lugar para compartir y volver a sentir.
            </p>
            <p>
              Gastronomía, cultura y buena vibra. Aquí, cada plato y cada evento hace de este mercado el punto vital de la ciudad. Donde el alma y la tradición encuentran un nuevo lugar.
            </p>
          </div>
        </div>

        <div class="relative h-[400px] md:h-[500px] w-full border-[12px] border-[#2c1e16] bg-[#2c1e16] transform rotate-2 hover:rotate-0 transition-transform duration-300">
          <img 
            src="/headerimagen2.webp" 
            alt="Nuestra Historia" 
            class="absolute inset-0 w-full h-full object-cover" 
          />
        </div>
      </div>
    </section>

    <section id="galeria" class="py-20 text-center text-gray-400 bg-[#111]">
      <h2 class="font-bebas text-4xl tracking-wider">GALERÍA DE FOTOS (Placeholder)</h2>
    </section>

    <Contacto />
  </main>

  <Footer />
</Layout>