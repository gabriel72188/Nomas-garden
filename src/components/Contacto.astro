---
// src/components/Contacto.astro
---

<section id="contacto" class="py-24 bg-gray-50 relative border-t border-gray-200">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="text-center mb-16">
      <h2 class="font-bebas text-5xl md:text-6xl text-gray-900 tracking-wider mb-4">¿DÓNDE ESTAMOS?</h2>
      <p class="font-sans text-gray-600 text-lg max-w-2xl mx-auto">Ven a visitarnos y disfruta de la mejor gastronomía en un ambiente único.</p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 bg-white rounded-2xl p-6 md:p-10 border border-gray-100 shadow-xl">
      
      <div class="flex flex-col justify-center space-y-10">
        
        <div class="flex items-start gap-5">
          <div class="bg-[#e4a055]/10 p-3.5 rounded-xl text-[#e4a055] shrink-0">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <div>
            <h3 class="font-bebas text-2xl tracking-wider text-gray-900 mb-1.5">UBICACIÓN</h3>
            <p class="font-sans text-gray-600 leading-relaxed">
              (Aquí pones tu dirección real)<br>
              Ciudad, Código Postal
            </p>
          </div>
        </div>

        <div class="flex items-start gap-5">
          <div class="bg-[#e4a055]/10 p-3.5 rounded-xl text-[#e4a055] shrink-0">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </div>
          <div>
            <h3 class="font-bebas text-2xl tracking-wider text-gray-900 mb-1.5">RESERVAS Y DUDAS</h3>
            <p class="font-sans text-gray-600 leading-relaxed">
              <a href="tel:640620913" class="hover:text-[#e4a055] transition-colors font-medium">+34 640 62 09 13</a><br>
              <a href="mailto:nomadsgardenmarket@gmail.com" class="hover:text-[#e4a055] transition-colors text-sm">nomadsgardenmarket@gmail.com</a>
            </p>
          </div>
        </div>

        <div class="flex items-start gap-5">
          <div class="bg-[#e4a055]/10 p-3.5 rounded-xl text-[#e4a055] shrink-0">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div>
            <h3 class="font-bebas text-2xl tracking-wider text-gray-900 mb-1.5">HORARIO</h3>
            <ul class="font-sans text-gray-600 space-y-1">
              <li><span class="font-semibold text-gray-800">Jueves:</span> 19:00 a 23:30</li>
              <li><span class="font-semibold text-gray-800">Vie y Sáb:</span> 12:00 a 16:00 y 19:00 a 00:00</li>
              <li><span class="font-semibold text-gray-800">Domingo:</span> 12:00 a 17:00</li>
            </ul>
          </div>
        </div>

      </div>

      <div class="h-[400px] lg:h-auto min-h-[400px] w-full rounded-xl overflow-hidden border border-gray-200 relative group">
        
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3192.146524823439!2d-1.9546!3d36.8624!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd7a9f8162343d2f%3A0x6b77c35f29c42490!2sAlmer%C3%ADa%2C%20Spain!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus" 
          class="absolute inset-0 w-full h-full border-0 transition-all duration-500" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>

      </div>

    </div>
  </div>
</section>